# ──────────────────────────────────────────────────────────────
#  Telegram Mini App — переменные окружения
#  Локально: скопируйте в .env.local. На Railway: задайте в Variables.
# ──────────────────────────────────────────────────────────────

# Токен бота от @BotFather (ОБЯЗАТЕЛЬНО в проде).
# Без него: авторизация в dev-режиме, бот не шлёт сообщения.
BOT_TOKEN=

# Строка подключения к PostgreSQL.
# На Railway: ${{Postgres.DATABASE_URL}} (Variable Reference).
DATABASE_URL=

# Telegram id админов/мастеров через запятую — у них открывается кабинет.
# Должно совпадать с masterTelegramIds в src/config/brand.ts.
MASTER_TELEGRAM_IDS=628854840

# Адрес студии, который бот шлёт клиенту после подтверждения записи.
# Пусто → бот напишет «адрес пришлёт отдельно».
STUDIO_ADDRESS=

# Публичный домен приложения (Railway задаёт автоматически как RAILWAY_PUBLIC_DOMAIN).
# Нужен для регистрации Telegram webhook. Локально можно не задавать.
RAILWAY_PUBLIC_DOMAIN=

# Порт сервера (Railway задаёт сам). Локально по умолчанию 3000.
PORT=3000

# Режим SSL для pg (на Railway обычно не требуется; задайте require при необходимости).
PGSSLMODE=

# Папка для загруженных изображений (эскизы, чеки).
# На Railway смонтируйте Volume на /data → оставьте STORAGE_DIR=/data/uploads.
# Локально по умолчанию ./.data/uploads.
STORAGE_DIR=
